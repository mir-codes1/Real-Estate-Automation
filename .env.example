# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on. Must match client/vite.config.js proxy
# (BACKEND_URL) when running dev server.
PORT=3000
NODE_ENV=development   # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite file (relative to project root).
# SQLite is used for local development only.
#
# PostgreSQL (production): replace better-sqlite3 with `pg`, update
# src/db/connection.js to use a connection pool, and set DATABASE_URL instead:
#   DATABASE_URL=postgresql://user:password@host:5432/real_estate
DB_PATH=./data/real_estate.db

# ─── AI ───────────────────────────────────────────────────────────────────────
# Google Gemini API key. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── n8n Automation ───────────────────────────────────────────────────────────
# Webhook URL that receives listing payloads.
# Dev default uses n8n's test webhook endpoint.
# Production: use the live webhook URL from your n8n instance.
N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/listing-automation

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed frontend origin. In production, set to your deployed frontend URL.
# Multiple origins are not supported with this config — use a comma-split array
# in app.js if you need more than one.
CORS_ORIGIN=http://localhost:5173
